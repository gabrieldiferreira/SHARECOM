  "description": "Gerencie e digitalize seus comprovantes financeiros com IA",
  "categories": ["finance", "productivity"],
  "shortcuts": [
    {
      "name": "Dashboard",
      "short_name": "Dashboard",
      "description": "Visão geral financeira",
      "url": "/?source=shortcut",
