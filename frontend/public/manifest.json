      "url": "/scanner?source=shortcut",
      "icons": [{ "src": "/icon-192x192.png", "sizes": "192x192" }]
    },
    {
      "name": "Ver Histórico",
      "short_name": "Histórico",
      "description": "Ver transações passadas",
      "url": "/timeline?source=shortcut",
      "icons": [{ "src": "/icon-192x192.png", "sizes": "192x192" }]
    },
    {
      "name": "Configurações",
      "short_name": "Ajustes",
      "description": "Preferências do app",
      "url": "/settings?source=shortcut",
      "icons": [{ "src": "/icon-192x192.png", "sizes": "192x192" }]
    }
  ],
  "share_target": {
    "action": "/api/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
